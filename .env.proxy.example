# Super Agent Monitor - 3-Layer Proxy Configuration
#
# This file defines the model routing for the 3-layer architecture:
# - BIG (Layer 1): Prime/Orchestrator - Strategic thinking
# - MIDDLE (Layer 2): Council - Tactical planning
# - SMALL (Layer 3): Swarm - Execution workers

# ============================================
# Model Tier Configuration
# ============================================

# BIG Model - For Prime/Orchestrator (strategic decisions)
# Recommendations: claude-3-opus, gpt-4, gemini-pro-1.5
BIG_MODEL=claude-3-opus-20240229
BIG_ENDPOINT=https://api.anthropic.com
BIG_API_KEY=${ANTHROPIC_API_KEY}
BIG_MAX_TOKENS=8192

# MIDDLE Model - For Council (tactical planning)
# Recommendations: claude-3-sonnet, gpt-4-turbo, gemini-flash
MIDDLE_MODEL=claude-sonnet-4-20250514
MIDDLE_ENDPOINT=https://api.anthropic.com
MIDDLE_API_KEY=${ANTHROPIC_API_KEY}
MIDDLE_MAX_TOKENS=4096

# SMALL Model - For Swarm workers (execution)
# Recommendations: claude-3-haiku, gpt-3.5-turbo, gemini-flash-8b
SMALL_MODEL=claude-3-haiku-20240307
SMALL_ENDPOINT=https://api.anthropic.com
SMALL_API_KEY=${ANTHROPIC_API_KEY}
SMALL_MAX_TOKENS=2048

# ============================================
# Proxy Server Configuration
# ============================================

# Claude Code Proxy settings
PROXY_HOST=127.0.0.1
PROXY_PORT=8180
ENABLE_STREAMING=true
LOG_REQUESTS=true

# ============================================
# Cost Optimization Settings
# ============================================

# Enable 3-layer routing
ENABLE_TIERED_ROUTING=true

# Route mapping (agent category -> model tier)
# council/ agents -> MIDDLE
# swarm/ agents -> SMALL
# orchestrator agents -> BIG

# Budget limits (USD)
DAILY_BUDGET=10.00
HOURLY_LIMIT=2.00

# ============================================
# Hybrid Mode (Multi-Provider)
# ============================================

# Enable hybrid mode for cost optimization
ENABLE_HYBRID_MODE=false

# Hybrid provider endpoints (optional)
# HYBRID_BIG_ENDPOINT=https://api.openai.com/v1
# HYBRID_BIG_API_KEY=${OPENAI_API_KEY}
# HYBRID_BIG_MODEL=gpt-4

# ============================================
# Local Model Fallback (Optional)
# ============================================

# Enable local model fallback for SMALL tier
ENABLE_LOCAL_FALLBACK=false
LOCAL_MODEL_ENDPOINT=http://localhost:11434
LOCAL_MODEL_NAME=llama2:7b
