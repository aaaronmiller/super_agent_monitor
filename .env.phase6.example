# 🔐 Ironclad Phase 6 - Environment Variables
# Extend .env.example with Phase 6 enterprise features
# Merge with existing .env.example for complete configuration

# ==================== PHASE 6: REAL-TIME COLLABORATION ====================
# Redis for WebSocket pub/sub and session storage
REDIS_PASSWORD=ironclad_secure_redis_password_123!
REDIS_URL=redis://redis:6379

# WebSocket Server Configuration
WS_PORT=8080
WS_HOST=0.0.0.0

# WebSocket Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-to-64-characters-exactly
SESSION_SECRET=your-session-secret-key-change-this-too-32-chars

# WebSocket Rate Limiting
WS_RATE_LIMIT_REQUESTS=50
WS_RATE_LIMIT_WINDOW=60

# Session Cleanup (in seconds)
SESSION_INACTIVITY_TIMEOUT=3600  # 1 hour
SESSION_MAX_DURATION=86400  # 24 hours

# ==================== PHASE 6: TEAM RBAC ====================
# Security and permissions
JWT_EXPIRY=24h
INVITE_TOKEN_EXPIRY=48  # hours
REQUIRE_2FA=false  # Set to true for production

# Default team settings
DEFAULT_SESSION_VISIBILITY=team
ALLOW_EXTERNAL_INVITES=false
MAX_TEAM_SIZE=50

# Audit logging
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_MAX_SIZE_MB=100

# ==================== PHASE 6: CI/CD INTEGRATION ====================
# GitHub Integration
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_API_URL=https://api.github.com

# GitLab Integration
GITLAB_TOKEN=glpat-your-gitlab-token
GITLAB_API_URL=https://gitlab.com/api/v4

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-for-ci-cd
WEBHOOK_TIMEOUT=10000  # 10 seconds
WEBHOOK_RETRY_ATTEMPTS=3

# Pipeline Configuration
PIPELINE_TIMEOUT=600  # 10 minutes
QUALITY_GATE_THRESHOLD=0.9  # 90% confidence required

# ==================== PHASE 6: SECURITY & CORS ====================
# CORS Configuration (comma-separated origins)
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW=60  # seconds
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BURST=20

# Security Headers
SECURITY_HEADERS_ENABLED=true
ENABLE_CSP=true
ENABLE_HSTS=true

# ==================== PHASE 6: MONITORING & OBSERVABILITY ====================
# Sentry Integration (optional)
SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/your-project
SENTRY_ENVIRONMENT=production

# Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Health Check
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5

# ==================== PHASE 6: DEPLOYMENT CONFIGURATION ====================
# URLs (update these for your domain)
PUBLIC_API_URL=https://api.yourdomain.com
PUBLIC_WS_URL=wss://api.yourdomain.com/ws
PUBLIC_FRONTEND_URL=https://yourdomain.com

# Internal Docker networking
BACKEND_URL=http://backend:3001
FRONTEND_URL=http://frontend:4173
REDIS_URL=redis://redis:6379

# Caddy/Proxy
ACME_EMAIL=your-email@example.com
CADDY_ADMIN=false

# ==================== PHASE 6: FEATURE FLAGS ====================
# Enable/disable Phase 6 features
ENABLE_REALTIME_COLLABORATION=true
ENABLE_TEAM_RBAC=true
ENABLE_CI_CD_INTEGRATION=true
ENABLE_AUDIT_LOGGING=true
ENABLE_ANALYTICS_DASHBOARD=true

# ==================== PHASE 6: PERFORMANCE TUNING ====================
# WebSocket Performance
WS_MAX_CONNECTIONS=1000
WS_MESSAGE_SIZE_LIMIT=1048576  # 1MB
WS_PING_INTERVAL=30000  # 30s
WS_PONG_TIMEOUT=10000  # 10s

# Redis Performance
REDIS_MAX_MEMORY=256mb
REDIS_POLICY=allkeys-lru
REDIS_SAVE_INTERVAL=60
REDIS_APPENDFSYNC=everysec

# Rate Limiting Strategy
RATE_LIMIT_STRATEGY=sliding-window  # or fixed-window

# ==================== PHASE 6: DEVELOPMENT MODE ====================
# Set to false for production
DEV_MODE=false

# Mock external services (for testing)
MOCK_GITHUB=false
MOCK_WEBHOOKS=false

# ==================== PHASE 6: INTEGRATIONS ====================
# Vector Database (optional - extends Phase 1-3)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=your-qdrant-key

# Pinecone (alternative vector DB)
PINECONE_API_KEY=your-pinecone-key
PINECONE_ENVIRONMENT=your-env
PINECONE_INDEX=your-index

# ==================== DOCKER COMPOSE PROFILES ====================
# Enable debug/monitoring tools (dev only)
# Uncomment to enable:
# COMPOSE_PROFILES=dev,debug

# ==================== ENVIRONMENT-SPECIFIC OVERRIDES ====================
# You can create .env.production.local for production-specific values
# The order of precedence is:
# 1. .env.local
# 2. .env.[NODE_ENV].local
# 3. .env
# 4. .env.[NODE_ENV]
# 5. .env.example

# ==================== SECURITY CHECKLIST ====================
# Before deploying production, ensure:
# ✅ JWT_SECRET is >= 32 characters (generate with: openssl rand -hex 32)
# ✅ REDIS_PASSWORD is strong and unique
# ✅ WEBHOOK_SECRET is generated and stored securely
# ✅ CORS_ORIGIN only includes your actual domains
# ✅ GITHUB_TOKEN has minimal required permissions (repo, workflow)
# ✅ All database credentials are changed from defaults
# ✅ Enable 2FA for team membership (REQUIRE_2FA=true)
# ✅ Review audit logs regularly
# ✅ Set up external monitoring (Sentry)
# ✅ Configure backup strategy for Redis/Postgres
# ✅ Use HTTPS/WSS in production (Caddy handles this automatically)

# ==================== GENERATE SECRETS ====================
# Run these commands to generate secure secrets:
#
# JWT Secret (64 chars):
#   openssl rand -hex 32
#
# Session Secret (32 chars):
#   openssl rand -hex 16
#
# Webhook Secret (32 chars):
#   openssl rand -hex 16
#
# Redis Password (use a password manager or generate):
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# ==================== EXAMPLE PRODUCTION SETUP ====================
# 1. Copy this to .env.production:
#    cp .env.phase6.example .env.production
#
# 2. Edit and fill in all required values
#
# 3. Generate secrets:
#    JWT_SECRET=$(openssl rand -hex 32)
#    SESSION_SECRET=$(openssl rand -hex 16)
#    WEBHOOK_SECRET=$(openssl rand -hex 16)
#
# 4. Set your domain:
#    CORS_ORIGIN=https://yourdomain.com
#    PUBLIC_API_URL=https://api.yourdomain.com
#    PUBLIC_WS_URL=wss://api.yourdomain.com/ws
#
# 5. Deploy:
#    docker-compose --env-file .env.production up -d
#
# 6. Verify:
#    curl https://api.yourdomain.com/health
#    curl https://yourdomain.com

# ==================== DEBUGGING ====================
# Set these to true for debugging:
# DEBUG_WS=false
# DEBUG_REDIS=false
# DEBUG_AUTH=false
# DEBUG_WEBHOOKS=false